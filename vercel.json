{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "regions": ["fra1"],
        "nativelyCompileRemotePatterns": [
          { "hostname": "**" }
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "TASK_CHAT_ENABLE_OPENCLAW_AGENT": "false",
    "OPENCLAW_GATEWAY_TOKEN": "placeholder",
    "OPENCLAW_GATEWAY_URL": "placeholder"
  }
}
